cat > .gitignore << 'EOF'
# Ambiente
.venv/
bev/
__pycache__/
*.pyc

# Dati e output pesanti/rigenerabili
outputs/
checkpoints/
multirun/
wandb/
*.pt
*.pth
*.log
data/

# Cache dataset
**/cache/

# Risultati/visualizzazioni (rigenerabili da test_inference.py)
viz_samples/
results.json
analysis_report.*
notebooks/inspect_results.ipynb
EOF
